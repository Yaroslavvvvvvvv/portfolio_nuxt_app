# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# PostgreSQL connection
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?schema=public"

# Session cookie secret (min 32 chars, random)
NUXT_SESSION_PASSWORD="change-me-to-a-random-32-char-string"

# Admin account created by `prisma db seed`
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# Public origin, used for canonical URLs, og:image and sitemap.xml.
# Must be the real domain in production (no trailing slash).
NUXT_PUBLIC_SITE_URL="http://localhost:3000"

# Image uploads. 'local' writes to NUXT_STORAGE_UPLOAD_DIR (fine for dev).
# In production use 's3' — container disks are wiped on every redeploy.
NUXT_STORAGE_DRIVER="local"
NUXT_STORAGE_UPLOAD_DIR=".data/uploads"

# Only needed when NUXT_STORAGE_DRIVER=s3 (Cloudflare R2, Backblaze B2, …)
# NUXT_STORAGE_S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
# NUXT_STORAGE_S3_BUCKET="studio-uploads"
# NUXT_STORAGE_S3_REGION="auto"
# NUXT_STORAGE_S3_ACCESS_KEY_ID=""
# NUXT_STORAGE_S3_SECRET_ACCESS_KEY=""
# NUXT_STORAGE_S3_PUBLIC_URL="https://cdn.example.com"
